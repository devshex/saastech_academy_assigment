<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.0.xsd"
        default-menu-title="Orders">

    <transition name="findOrder">
        <default-response url="."/>
    </transition>

    <transition name="createOrder">
        <service-call name="create#ordermgmtsystem.OrderHeader" in-map="context"/>
        <default-response url="."/>
    </transition>

    <actions>
        <entity-find entity-name="ordermgmtsystem.OrderHeader" list="orderList">
            <search-form-inputs default-order-by="-orderDate"/>
        </entity-find>
    </actions>

    <widgets>
        <container-panel id="OrderPanel" dynamic="true">
            <panel-left>
                <label text="Find Orders" type="h2"/>
                <form-single name="FindOrders" transition="findOrder">
                    <field name="orderId"><default-field><text-find/></default-field></field>
                    <field name="orderName"><default-field><text-find/></default-field></field>
                    <field name="submitButton"><default-field title="Search"><submit/></default-field></field>
                </form-single>

                <label text="Create Order" type="h2"/>
                <form-single name="CreateOrder" transition="createOrder">
                    <field name="orderId"><default-field><text-line size="20"/></default-field></field>
                    <field name="orderName"><default-field><text-line size="40"/></default-field></field>
                    <field name="orderDate"><default-field><date-time/></default-field></field>
                    <field name="grandTotal"><default-field><text-line size="10"/></default-field></field>
                    <field name="submitButton"><default-field title="Create"><submit/></default-field></field>
                </form-single>
            </panel-left>
            <panel-center>
                <form-list name="OrderList" list="orderList" transition="findOrder">
                    <field name="orderId"><default-field><display/></default-field></field>
                    <field name="orderName"><default-field><display/></default-field></field>
                    <field name="orderDate"><default-field><display/></default-field></field>
                    <field name="grandTotal"><default-field><display/></default-field></field>
                </form-list>
            </panel-center>
        </container-panel>
    </widgets>
</screen>