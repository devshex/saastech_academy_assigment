<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.0.xsd">
    <entity entity-name="OrderHeader" package="ordermgmtsystem">
        <field name="orderId" type="id" is-pk="true"/>
        <field name="orderName" type="text-medium"/>
        <field name="orderDate" type="date-time"/>
        <field name="statusId" type="id"/>
        <field name="currencyUomId" type="id"/>
        <field name="grandTotal" type="currency-amount"/>
    </entity>
    
    <entity entity-name="OrderItem" package="ordermgmtsystem">
        <field name="orderId" type="id" is-pk="true"/>
        <field name="orderItemSeqId" type="id" is-pk="true"/>
        <field name="productId" type="id"/>
        <field name="quantity" type="number-decimal"/>
        <field name="unitPrice" type="currency-amount"/>
        <field name="itemDescription" type="text-medium"/>
        <relationship type="one" related="ordermgmtsystem.OrderHeader"/>
    </entity>

    <entity entity-name="OrderStatus" package="ordermgmtsystem">
        <field name="orderStatusId" type="id" is-pk="true"/>
        <field name="statusId" type="id"/>
        <field name="orderId" type="id"/>
        <field name="statusDate" type="date-time"/>
        <relationship type="one" related="ordermgmtsystem.OrderHeader"/>
    </entity>
    
    <entity entity-name="OrderContactMech" package="ordermgmtsystem">
        <field name="orderId" type="id" is-pk="true"/>
        <field name="contactMechPurposeTypeId" type="id" is-pk="true"/>
        <field name="contactMechId" type="id"/>
        <relationship type="one" related="ordermgmtsystem.OrderHeader"/>
    </entity>
    
    <entity entity-name="OrderAdjustment" package="ordermgmtsystem">
        <field name="orderAdjustmentId" type="id" is-pk="true"/>
        <field name="orderId" type="id"/>
        <field name="orderItemSeqId" type="id"/>
        <field name="orderAdjustmentTypeId" type="id"/>
        <field name="amount" type="currency-amount"/>
        <relationship type="one" related="ordermgmtsystem.OrderHeader"/>
    </entity>
    
    <entity entity-name="OrderPaymentPreference" package="ordermgmtsystem">
        <field name="orderPaymentPreferenceId" type="id" is-pk="true"/>
        <field name="orderId" type="id"/>
        <field name="paymentMethodTypeId" type="id"/>
        <field name="statusId" type="id"/>
        <field name="maxAmount" type="currency-amount"/>
        <relationship type="one" related="ordermgmtsystem.OrderHeader"/>
    </entity>
</entities>