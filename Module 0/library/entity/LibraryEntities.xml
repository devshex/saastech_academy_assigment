<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">


<!--    this is independent table author which can exist with any book-->
<entity entity-name="Author" package="tutorial.library">
<!--    primary key-->
    <field name="authorId" type="id" is-pk="true"/>
    <field name="fullName" type="text-medium"/>
    <field name="bio" type="text-long"/>
</entity>

<!--    now making the table which can't exist without any relation with the table also
'authorId acting as a fk in this table-->
    <entity entity-name="Book" package="tutorial.library">
        <field name="bookId" type="id" is-pk="true"/>
        <field name="title" type="text-medium"/>
        <field name="genre" type="text-medium"/>

        <!--making the relation b/w book and author-->
        <field name="authorId" type="id"/>

<!--        this can act as both one-to-one and one-to-many-->
        <relationship type="one" related="tutorial.library.Author" short-alias="author"/>

    </entity>

</entities>