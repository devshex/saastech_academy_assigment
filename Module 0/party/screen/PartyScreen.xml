<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://moqui.org/xsd/xml-screen-3.xsd"
        default-menu-title="Party List"
        require-authentication="anonymous-all">

    <transition name="createPersonRecord">
        <actions>
            <set field="partyId" from="ec.entity.sequencedIdPrimary('tutorial.party.Party', null, null)"/>
            <service-call name="party.PartyService.create#Person" in-map="context"/>
        </actions>
        <default-response url="."/>
    </transition>

    <transition name="createGroupRecord">
        <actions>
            <set field="partyId" from="ec.entity.sequencedIdPrimary('tutorial.party.Party', null, null)"/>
            <service-call name="party.PartyService.create#PartyGroup" in-map="context"/>
        </actions>
        <default-response url="."/>
    </transition>

    <actions>
        <entity-find entity-name="tutorial.party.Party" list="partyList">
            <search-form-inputs default-order-by="-partyId"/>
        </entity-find>
    </actions>

    <widgets>
        <container-box>
            <box-header title="Party Records Configuration">

                <container-dialog id="CreatePersonDialog" button-text="Add Person">
                    <form-single name="CreatePersonForm" transition="createPersonRecord">
                        <field name="firstName">
                            <default-field title="First Name"><text-line/></default-field>
                        </field>
                        <field name="lastName">
                            <default-field title="Last Name"><text-line/></default-field>
                        </field>
                        <field name="submitButton">
                            <default-field title="Save Person"><submit/></default-field>
                        </field>
                    </form-single>
                </container-dialog>

                <container-dialog id="CreateGroupDialog" button-text="Add Group">
                    <form-single name="CreateGroupForm" transition="createGroupRecord">
                        <field name="groupName">
                            <default-field title="Group Name"><text-line/></default-field>
                        </field>
                        <field name="description">
                            <default-field title="Description"><text-area rows="3" cols="40"/></default-field>
                        </field>
                        <field name="submitButton">
                            <default-field title="Save Group"><submit/></default-field>
                        </field>
                    </form-single>
                </container-dialog>

            </box-header>

            <box-body>
                <form-list name="PartyListForm" list="partyList">

                    <field name="profileLink">
                        <header-field title="Action"/>
                        <default-field>
                            <link url="../PersonProfile" condition="partyTypeEnumId == 'PERSON'" text="View Profile" parameter-map="[partyId:partyId]" btn-type="primary"/>
                            <link url="../GroupProfile" condition="partyTypeEnumId == 'PARTY_GROUP'" text="View Profile" parameter-map="[partyId:partyId]" btn-type="primary"/>
                            <!-- Fallback -->
                            <link url="../PersonProfile" condition="partyTypeEnumId != 'PERSON' &amp;&amp; partyTypeEnumId != 'PARTY_GROUP'" text="View Profile" parameter-map="[partyId:partyId]" btn-type="primary"/>
                        </default-field>
                    </field>

                    <auto-fields-entity entity-name="tutorial.party.Party" field-type="find-display"/>
                </form-list>
            </box-body>
        </container-box>
    </widgets>
</screen>